@model IEnumerable<ShopMaster.Models.Shipment>

@{
    ViewData["Title"] = "الشحنات";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 25px 30px;
        border-radius: 15px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-modern {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
    }

    .table-modern {
        width: 100%;
        border-collapse: collapse;
    }

        .table-modern thead {
            background: #f8fafc;
        }

        .table-modern th {
            padding: 15px;
            font-weight: 600;
            color: #334155;
            border-bottom: 2px solid #e2e8f0;
            text-align: left;
        }

        .table-modern td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            color: #475569;
        }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-delivered {
        background: #dcfce7;
        color: #166534;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-modern {
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 0.85rem;
        text-decoration: none;
        font-weight: 600;
        margin-right: 5px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .btn-edit {
        background: #e0f2fe;
        color: #0369a1;
    }

    .btn-details {
        background: #ede9fe;
        color: #5b21b6;
    }

    .btn-delete {
        background: #fee2e2;
        color: #b91c1c;
    }

    .btn-create {
        background: white;
        color: #4f46e5;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
    }
</style>

<!-- Header -->
<div class="page-header">
    <h2><i class="fas fa-truck"></i> إدارة الشحنات</h2>
    <a asp-action="Create" class="btn-create">
        <i class="fas fa-plus"></i> شحنة جديدة
    </a>
</div>

<div class="card-modern">
    <table class="table-modern">
        <thead>
            <tr>
                <th>رقم التتبع</th>
                <th>شركة الشحن</th>
                <th>تاريخ الشحن</th>
                <th>تاريخ التسليم</th>
                <th>الحالة</th>
                <th>رقم الطلب</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TrackingNumber</td>
                    <td>@item.ShippingCompany</td>
                    <td>@item.ShippedDate?.ToString("yyyy/MM/dd")</td>
                    <td>@item.DeliveryDate?.ToString("yyyy/MM/dd")</td>
                    <td>
                        @{
                            string statusClass = item.Status.ToString() switch
                            {
                                "Delivered" => "status-badge status-delivered",
                                "Cancelled" => "status-badge status-cancelled",
                                _ => "status-badge status-pending"
                            };
                        }
                        <span class="@statusClass">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.Order?.OrderNumber</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-modern btn-edit">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-modern btn-details">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-modern btn-delete">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
