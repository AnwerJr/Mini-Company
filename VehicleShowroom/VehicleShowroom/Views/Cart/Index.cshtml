@model List<CartItem>

<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">🛒 Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            Cart is empty 🛒
        </div>
    }
    else
    {
        <table class="table table-bordered align-middle text-center shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="~/images/@item.ImageUrl"
                                 width="90"
                                 class="rounded shadow-sm" />
                        </td>
                        <td>@item.Name</td>
                        <td>
                            <span class="badge bg-secondary">@item.Type</span>
                        </td>
                        <td>@item.Total.ToString("C0")</td>

                        <!-- 🔢 Quantity -->
                        <td>
                            <a asp-controller="Cart"
                               asp-action="Decrease"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">➖</a>

                            <span class="mx-2 fw-bold">@item.Quantity</span>

                            <a asp-controller="Cart"
                               asp-action="Increase"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-success">➕</a>
                        </td>

                        <!-- 💰 Total -->
                        <td class="fw-bold text-success">
                            @(item.Price* item.Quantity).ToString("C0")
                        </td>

                        <!-- ❌ Remove -->
                        <td>
                            <a asp-controller="Cart"
                               asp-action="Remove"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">
                                ❌ Remove
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- 💳 Checkout -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <h4 class="fw-bold">
                Total:
                <span class="text-success">
                    @Model.Sum(x => x.Price * x.Quantity
                    ).ToString("C0")
                </span>
            </h4>

            <a class="btn btn-lg btn-primary px-5">
                💳 Checkout
            </a>
        </div>
    }
</div>
